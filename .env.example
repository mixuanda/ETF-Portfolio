# Backend server port
PORT=4000

# Frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:5173

# Optional DB path override (defaults to ./database/portfolio.db)
# DB_PATH=database/portfolio.db
# On Vercel, default fallback is /tmp/portfolio.db when DB_PATH is unset.

# Default quote provider: yahoo or demo
# demo only works when ENABLE_DEMO_MODE=true
DEFAULT_QUOTE_PROVIDER=yahoo

# Request timeout for quote providers (milliseconds)
REQUEST_TIMEOUT_MS=8000

# Enable HKEX quote provider as Yahoo backup source
ENABLE_HKEX_BACKUP=true

# Enables explicit demo/testing mode.
# false = normal mode (never uses demo data automatically)
ENABLE_DEMO_MODE=false

# Allows Yahoo -> Demo fallback only when ENABLE_DEMO_MODE=true.
# false = no automatic demo fallback
ALLOW_DEMO_FALLBACK=false

# Firebase program (optional): sync selected symbols and purchases to Firestore
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep newline characters escaped as \n
FIREBASE_PRIVATE_KEY=
FIREBASE_PORTFOLIO_ID=default
FIREBASE_RESTORE_ON_BOOT=true
