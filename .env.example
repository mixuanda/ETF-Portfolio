# Backend server port
PORT=4000

# Frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:5173

# Optional DB path override (defaults to ./database/portfolio.db)
# DB_PATH=database/portfolio.db

# Default quote provider: yahoo or demo
# demo only works when ENABLE_DEMO_MODE=true
DEFAULT_QUOTE_PROVIDER=yahoo

# Enables explicit demo/testing mode.
# false = normal mode (never uses demo data automatically)
ENABLE_DEMO_MODE=false

# Allows Yahoo -> Demo fallback only when ENABLE_DEMO_MODE=true.
# false = no automatic demo fallback
ALLOW_DEMO_FALLBACK=false
